# Supabase — frontend (safe to expose; protected by Row Level Security)
# Copy this file to `.env` and fill in your project's values.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Server-side only — NEVER expose to the frontend or commit.
# Used solely for seeding and admin scripts (e.g. creating the first admin).
# Keep this in your shell / CI secrets, not in any committed .env.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
